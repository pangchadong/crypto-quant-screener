# ============================================================
# Crypto Quant Screener — Environment Variables
# ============================================================
# วิธีใช้:
# 1. คัดลอกไฟล์นี้เป็น .env.local
# 2. แก้ไขค่าทุกอย่างให้ถูกต้อง
# 3. รัน: npm run dev

# ── Supabase ──────────────────────────────────────────────
# ได้จาก: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Bitkub API (ไม่บังคับสำหรับ Public endpoints) ────────
# ได้จาก: https://www.bitkub.com/settings/api
BITKUB_API_KEY=
BITKUB_API_SECRET=
BITKUB_BASE_URL=https://api.bitkub.com

# ── Cron Job Security ─────────────────────────────────────
# ใส่ random string ยาวๆ เช่น: openssl rand -hex 32
CRON_SECRET=change-this-to-a-random-secret-string

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
